{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            id as user_id,\n            display_name,\n            avatar_url,\n            best_score as score,\n            games_played as games_count,\n            leaderboard_public\n        FROM users\n        WHERE games_played > 0 AND deleted_at IS NULL\n        ORDER BY best_score DESC, games_played DESC\n        LIMIT $1 OFFSET $2\n        ",
