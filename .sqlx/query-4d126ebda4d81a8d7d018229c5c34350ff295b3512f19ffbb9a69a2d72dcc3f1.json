{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            id as user_id,\n            display_name,\n            avatar_url,\n            ROUND(total_score::numeric / games_played, 0)::bigint as \"score!: i64\",\n            games_played as games_count,\n            leaderboard_public\n        FROM users\n        WHERE games_played >= 3\n        ORDER BY (total_score::numeric / games_played) DESC, games_played DESC\n        LIMIT $1 OFFSET $2\n        ",
