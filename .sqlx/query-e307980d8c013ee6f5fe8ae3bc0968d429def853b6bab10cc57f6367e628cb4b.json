  "query": "\n        SELECT \n            id as user_id,\n            display_name,\n            avatar_url,\n            games_played as score,\n            games_played as games_count,\n            leaderboard_public\n        FROM users\n        WHERE games_played > 0\n        ORDER BY games_played DESC, total_score DESC\n        LIMIT $1 OFFSET $2\n        ",
